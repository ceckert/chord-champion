<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sprite Test — Forest Biome</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0a0a; overflow: hidden; }
    canvas { display: block; }
    #loading {
      position: fixed; inset: 0; background: #0a0a1e;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      font-family: monospace; color: #a78bfa; gap: 16px; z-index: 100;
    }
    #loading h2 { font-size: 20px; }
    #load-bar-bg { width: 280px; height: 14px; background: #1a0a2e; border-radius: 7px; border: 1px solid #4b2d8a; }
    #load-bar { height: 100%; background: linear-gradient(90deg,#7c3aed,#a855f7); border-radius: 7px; width: 0%; transition: width 0.2s; }
    #load-label { font-size: 12px; color: #6b7280; }
    #back-btn {
      position: fixed; top: 10px; left: 10px; z-index: 10;
      background: rgba(0,0,0,0.6); border: 1px solid #7c3aed;
      color: #a78bfa; font-family: monospace; font-size: 12px;
      padding: 6px 12px; border-radius: 6px; cursor: pointer; text-decoration: none;
    }
  </style>
</head>
<body>
<div id="loading">
  <h2>🌲 Loading Forest Sprites...</h2>
  <div id="load-bar-bg"><div id="load-bar"></div></div>
  <div id="load-label">Preparing sprites...</div>
</div>
<a href="/game/" id="back-btn">← Back to game</a>
<canvas id="c"></canvas>
<script src="/sprite-test.js?v=1"></script>
</body>
</html>
