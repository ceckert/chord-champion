---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import siteData from '../data/site.json';
---
<Layout title={`Services | ${siteData.businessName}`} description={`Professional services offered by ${siteData.businessName}`}>
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Services</h1>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">{siteData.description}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {siteData.services.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gray-50 text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Need a Custom Solution?</h2>
      <p class="text-gray-600 mb-8">We tailor our services to fit your specific needs. Get in touch to discuss how we can help.</p>
      <a href="/contact" class="btn-primary text-lg">Contact Us</a>
    </div>
  </section>
</Layout>
