---
interface Props {
  images: Array<{ url: string; alt: string; caption?: string }>;
}
const { images } = Astro.props;
---
<div class="grid grid-cols-2 md:grid-cols-3 gap-4">
  {images.map((img) => (
    <div class="group relative overflow-hidden rounded-lg aspect-square">
      <img src={img.url} alt={img.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
      {img.caption && (
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-300 flex items-end">
          <p class="text-white p-3 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">{img.caption}</p>
        </div>
      )}
    </div>
  ))}
</div>
