---
import siteData from '../data/site.json';

const socialIcons: Record<string, string> = {
  facebook: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  google: 'M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z',
};
const socialEntries = Object.entries(siteData.social).filter(([_, url]) => url);

const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
---
<footer class="bg-gray-900 text-gray-300 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Contact -->
      <div>
        <h3 class="text-white text-lg font-bold mb-4">{siteData.businessName}</h3>
        <p class="mb-2">{siteData.address.street}</p>
        <p class="mb-2">{siteData.address.city}, {siteData.address.state} {siteData.address.zip}</p>
        <p class="mb-2"><a href={`tel:${siteData.phone}`} class="hover:text-white transition">{siteData.phone}</a></p>
        <p><a href={`mailto:${siteData.email}`} class="hover:text-white transition">{siteData.email}</a></p>
      </div>
      <!-- Hours -->
      <div>
        <h3 class="text-white text-lg font-bold mb-4">Business Hours</h3>
        <ul class="space-y-1 text-sm">
          {days.map(day => {
            const h = (siteData.hours as any)[day];
            return (
              <li class="flex justify-between">
                <span>{day}</span>
                <span>{h === 'closed' ? 'Closed' : `${h.open} – ${h.close}`}</span>
              </li>
            );
          })}
        </ul>
      </div>
      <!-- Links + Social -->
      <div>
        <h3 class="text-white text-lg font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2 mb-6">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li><a href="/services" class="hover:text-white transition">Services</a></li>
          <li><a href="/about" class="hover:text-white transition">About</a></li>
          <li><a href="/contact" class="hover:text-white transition">Contact</a></li>
        </ul>
        {socialEntries.length > 0 && (
          <div class="flex gap-3">
            {socialEntries.map(([platform, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition" aria-label={platform}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  {socialIcons[platform] && <path d={socialIcons[platform]} />}
                </svg>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
      <p>&copy; {new Date().getFullYear()} {siteData.businessName}. All rights reserved.</p>
      {siteData.nucrew.poweredBy && (
        <a href="https://nucrew.ai" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-300 transition text-xs">
          Powered by NuCrew
        </a>
      )}
    </div>
  </div>
</footer>
