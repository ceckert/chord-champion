---
interface Props {
  name: string;
  description: string;
  price?: string;
  image?: string;
}
const { name, description, price, image } = Astro.props;
---
<div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group">
  {image && (
    <div class="h-48 overflow-hidden">
      <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </div>
  )}
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2">{name}</h3>
    <p class="text-gray-600 mb-3 text-sm leading-relaxed">{description}</p>
    {price && <p class="font-semibold" style="color: rgb(var(--color-primary))">{price}</p>}
  </div>
</div>
